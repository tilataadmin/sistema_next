{
  "rewrites": [
    { 
      "source": "/manual/:path((?!404.html).*)", 
      "destination": "/manual/404.html" 
    }
  ],
  "crons": [
    {
      "path": "/api/cron/auto-absences",
      "schedule": "0 6 * * 1-5"
    },
    {
      "path": "/api/cron/probation-report",
      "schedule": "0 12 1 * *"
    }
  ]
}
